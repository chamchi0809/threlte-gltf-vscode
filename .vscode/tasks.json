{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch:ext",
      "type": "npm",
      "script": "watch:ext",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "✘ \\[ERROR\\] (.+)",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      },
      "group": "build"
    },
    {
      "label": "watch:test",
      "type": "shell",
      "command": "npx tsc -p tsconfig.test.json --watch --preserveWatchOutput",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "group": "build"
    },
    {
      "label": "watch",
      "dependsOn": ["watch:ext", "watch:test"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
